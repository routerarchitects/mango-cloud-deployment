TTP_PORT=8088
SYSTEM_LOG_LEVEL=error


KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_CMD=service_events
KAFKA_TOPIC_RESP=service_events
KAFKA_GROUP_ID=service_group_id
KAFKA_DIAL_TIMEOUT=5s
KAFKA_WRITE_TIMEOUT=15s
KAFKA_READ_TIMEOUT=5s
KAFKA_MIN_BYTES=1
KAFKA_MAX_BYTES=1048576
KAFKA_ALLOW_AUTO_CREATE=true
KAFKA_TOPIC_LIFECYCLE=service_events


INTERNAL_RESTAPI_HOST_CERT=/app/certs/restapi-cert.pem
INTERNAL_RESTAPI_HOST_KEY=/app/certs/restapi-key.pem
INTERNAL_RESTAPI_HOST_ROOTCA=/app/certs/restapi-ca.pem


SYSTEM_URI_PRIVATE=https://nwtopology.wlan.local:17007
SYSTEM_URI_PUBLIC=https://openwifi.wlan.local:16007

SERVICE_TYPE=nwtopology
LIFECYCLE_INTERVAL=60s
KAFKA_OFFSET_RESET=false
PRIVATE_HTTP_PORT=17007

